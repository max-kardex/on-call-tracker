# ============ REQUIRED ============

# Database - PostgreSQL connection string
# For Vercel: use Vercel Postgres, Neon, or Supabase
# For Docker: use the docker-compose PostgreSQL instance
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/oncall_tracker"

# Auth.js secret - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
# Callback URL: https://your-domain.vercel.app/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ============ OPTIONAL ============

# Only needed for local development. Do NOT set on Vercel (auto-detected).
NEXTAUTH_URL="http://localhost:3000"

# Slack webhook (can also be configured in the Settings UI)
SLACK_WEBHOOK_URL=""
