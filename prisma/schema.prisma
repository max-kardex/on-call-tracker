generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ AUTH MODELS (NextAuth) ============

model User {
  id               String         @id @default(cuid())
  name             String?
  fullName         String?
  email            String?        @unique
  emailVerified    DateTime?
  image            String?
  roles            Role[]         @default([ENGINEER])
  preferredContact ContactMethod  @default(SLACK)
  onboarded        Boolean        @default(false)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  accounts      Account[]
  sessions      Session[]

  // On-call relations
  schedules         Schedule[]
  callLogs          CallLog[]
  swapPostsCreated  SwapPost[] @relation("SwapPoster")
  swapPostsClaimed  SwapPost[] @relation("SwapClaimer")
  dayCoverages      DayCoverage[]
  ptoCompensations  PtoCompensation[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ APPLICATION MODELS ============

enum Role {
  ADMIN
  MANAGER
  ENGINEER
  SUPPORT
}

enum ContactMethod {
  SMS
  SLACK
  TEAMS
  CALL
}

enum Severity {
  P1
  P2
  P3
  P4
}

enum SwapStatus {
  OPEN
  CLAIMED
  CANCELLED
}

enum SwapPostType {
  GIVE_AWAY
  SWAP
}

enum CoverageType {
  FULL_WEEK
  SPECIFIC_DAYS
}

// Weekly on-call schedule assignment
model Schedule {
  id             String   @id @default(cuid())
  userId         String
  weekStart      DateTime // Monday of the on-call week
  weekEnd        DateTime // Sunday end of the on-call week
  isOverride     Boolean  @default(false)
  isSelfAssigned Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  callLogs CallLog[]
  dayCoverages DayCoverage[]

  @@unique([userId, weekStart])
  @@index([weekStart])
}

// Individual call log entry
model CallLog {
  id          String   @id @default(cuid())
  scheduleId  String
  userId      String
  severity    Severity
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int?     // Duration in minutes
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  schedule Schedule @relation(fields: [scheduleId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([scheduleId])
  @@index([userId])
  @@index([severity])
  @@index([startTime])
}

// Swap board post: an engineer offers up a week or specific days
// for someone else to take (give away) or trade (swap)
model SwapPost {
  id               String       @id @default(cuid())
  posterId         String
  claimerId        String?
  status           SwapStatus   @default(OPEN)
  postType         SwapPostType // GIVE_AWAY | SWAP
  coverageType     CoverageType // FULL_WEEK | SPECIFIC_DAYS
  weekStart        DateTime     // Monday of the poster's week
  specificDays     DateTime[]   // For SPECIFIC_DAYS coverage: which days within the week
  offeredWeekStart DateTime?    // For SWAP claims: claimer's offered week
  offeredDays      DateTime[]   // For SWAP + SPECIFIC_DAYS claims: claimer's offered days
  reason           String?
  claimedAt        DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  poster       User          @relation("SwapPoster", fields: [posterId], references: [id])
  claimer      User?         @relation("SwapClaimer", fields: [claimerId], references: [id])
  dayCoverages DayCoverage[]

  @@index([posterId])
  @@index([claimerId])
  @@index([status])
  @@index([weekStart])
}

// Day-level coverage override (created when specific-days swaps are claimed)
model DayCoverage {
  id         String   @id @default(cuid())
  date       DateTime // The specific day being covered
  userId     String   // Who is covering this day
  scheduleId String   // Which Schedule entry this overrides
  swapPostId String   // The SwapPost that produced this coverage
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  schedule Schedule @relation(fields: [scheduleId], references: [id])
  swapPost SwapPost @relation(fields: [swapPostId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([userId])
  @@index([date])
}

// PTO compensation records
model PtoCompensation {
  id          String   @id @default(cuid())
  userId      String
  periodStart DateTime
  periodEnd   DateTime
  hoursEarned Float
  reason      String
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([periodStart, periodEnd])
}

// Admin-configurable compensation rules
model CompensationRule {
  id          String    @id @default(cuid())
  name        String
  description String?
  ruleType    String
  value       Float
  severity    Severity?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Custom holidays (US federal holidays are computed at runtime)
model Holiday {
  id        String   @id @default(cuid())
  date      DateTime
  name      String
  isCustom  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([date])
}

// Slack integration configuration
model SlackConfig {
  id                    String  @id @default(cuid())
  webhookUrl            String
  channelName           String?
  notifyOnRotation      Boolean @default(true)
  notifyOnSwap          Boolean @default(true)
  notifyOnHighSeverity  Boolean @default(true)
  isActive              Boolean @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
